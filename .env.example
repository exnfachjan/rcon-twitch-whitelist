# ── Twitch App ────────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Twitch OAuth Tokens ───────────────────────────────────────────
# Generate: https://id.twitch.tv/oauth2/authorize?client_id=CLIENT_ID&redirect_uri=http://localhost&response_type=code&scope=channel:read:redemptions+chat:read+chat:edit
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# ── Twitch Bot Account ────────────────────────────────────────────
TWITCH_BOT_USERNAME=
# Token from https://twitchtokengenerator.com (with oauth: prefix)
TWITCH_BOT_TOKEN=oauth:

# ── Twitch Channel ────────────────────────────────────────────────
TWITCH_CHANNEL=
# Get Broadcaster ID:
# curl -H "Client-Id: CLIENT_ID" -H "Authorization: Bearer ACCESS_TOKEN" "https://api.twitch.tv/helix/users?login=CHANNEL"
TWITCH_BROADCASTER_ID=
# Exact name of the channel points reward
TWITCH_REWARD_TITLE=SMP

# ── Minecraft RCON ────────────────────────────────────────────────
RCON_HOST=host.docker.internal
RCON_PORT=25575
RCON_PASSWORD=

# ── Bot Language ──────────────────────────────────────────────────
# EN = English, DE = German
BOT_LANGUAGE=EN
