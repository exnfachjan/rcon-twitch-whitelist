# ── Twitch App ────────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ── Twitch OAuth Tokens ───────────────────────────────────────────
# Generieren: https://id.twitch.tv/oauth2/authorize?client_id=CLIENT_ID&redirect_uri=http://localhost&response_type=code&scope=channel:read:redemptions+chat:read+chat:edit
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# ── Twitch Bot Account ────────────────────────────────────────────
TWITCH_BOT_USERNAME=
# Token von https://twitchtokengenerator.com (mit oauth: prefix)
TWITCH_BOT_TOKEN=oauth:

# ── Twitch Kanal ──────────────────────────────────────────────────
TWITCH_CHANNEL=
# Broadcaster ID herausfinden:
# curl -H "Client-Id: CLIENT_ID" -H "Authorization: Bearer ACCESS_TOKEN" "https://api.twitch.tv/helix/users?login=KANAL"
TWITCH_BROADCASTER_ID=
# Exakter Name der Kanalpunktebelohnung
TWITCH_REWARD_TITLE=SMP

# ── Minecraft RCON ────────────────────────────────────────────────
RCON_HOST=host.docker.internal
RCON_PORT=25575
RCON_PASSWORD=
